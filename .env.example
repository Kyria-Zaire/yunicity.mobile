# ── MongoDB local (Docker) ──
MONGO_ROOT_USER=yunicity
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── PostgreSQL local (Docker) ──
DATABASE_URL=postgresql://yunicity:changeme_local@localhost:5432/yunicity

# ── Redis local (Docker) ──
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Auth secret (min 32 caractères aléatoires) ──
AUTH_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING_HERE

# ── Mobile (Expo) ──
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ── Inter-services (optionnel) — CSV des noms autorisés pour X-Internal-Service
# INTERNAL_SERVICE_NAMES=user-service,payment-service,worker

# ── MongoDB Atlas (production) ──
MONGODB_ATLAS_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/yunicity?retryWrites=true&w=majority
