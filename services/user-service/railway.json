{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "../../docker/node-service.Dockerfile",
    "dockerfileContext": "../..",
    "buildArgs": {
      "SERVICE_DIR": "user-service",
      "EXPOSE_PORT": "3002",
      "PNPM_FILTER": "@yunicity/user-service",
      "RUNNER_HEALTH": "1"
    }
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma && node dist/index.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
