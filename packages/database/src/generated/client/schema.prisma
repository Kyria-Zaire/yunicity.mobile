generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────

enum ProfileType {
  yunicitizen
  commercial
  association
  freelance
  ecole
}

enum VerificationStatus {
  pending
  under_review
  verified
  rejected
}

enum SubscriptionPlan {
  free
  premium
}

enum TribeCategory {
  culture
  sport
  business
  education
  social
  ecology
  food
  art
  tech
  other
}

enum PostType {
  text
  event
  offer
  question
  announcement
}

enum PartnerStatus {
  lead
  contacted
  negotiating
  active
  paused
  churned
}

enum PartnerTier {
  standard
  premium
}

enum PartnerSource {
  inscription
  referral
  cold_outreach
  event
}

// ── User ────────────────────────────────────────────────

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  phone        String?     @unique
  passwordHash String
  profileType  ProfileType

  // Verification
  verificationStatus VerificationStatus @default(pending)
  verifiedAt         DateTime?
  autoVerified       Boolean            @default(false)
  emailVerified      Boolean            @default(false)

  // Localisation (PostGIS)
  city     String?
  quartier String?
  cp       String?
  lat      Float?
  lng      Float?

  // Donnees profil specifiques
  profileData Json @default("{}")

  // Securite
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  lastLoginIp   String?
  lastLoginAt   DateTime?

  // Gamification
  points          Int      @default(0)
  level           Int      @default(1)
  badges          String[] @default([])
  ambassadorLabel String?
  weeklyRank      Int?

  // Abonnement
  plan             SubscriptionPlan @default(free)
  stripeCustomerId String?
  periodEnd        DateTime?

  // RGPD
  consentRgpd      Boolean  @default(false)
  consentRgpdDate  DateTime @default(now())
  consentMarketing Boolean  @default(false)
  consentAnalytics Boolean  @default(false)

  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  kycDocuments      KycDocument[]
  tribeMembers      TribeMember[]
  tribeCreated      Tribe[]            @relation("TribeCreator")
  posts             Post[]
  reactions         Reaction[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([profileType, verificationStatus])
  @@index([city, profileType])
  @@index([deletedAt])
  @@index([lat, lng])
}

// ── KYC Documents ───────────────────────────────────────

model KycDocument {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  type            String // kbis | rna | siret | urssaf | uai | other
  r2Key           String // Cle R2 — jamais l'URL publique
  uploadedAt      DateTime  @default(now())
  reviewedAt      DateTime?
  reviewerId      String?
  rejectionReason String?

  @@index([userId])
}

// ── Sessions Better Auth ─────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

// ── Tribes ──────────────────────────────────────────────

model Tribe {
  id          String        @id @default(cuid())
  name        String
  slug        String
  description String
  category    TribeCategory
  city        String

  // Localisation PostGIS
  lat Float?
  lng Float?

  creatorId    String
  creator      User          @relation("TribeCreator", fields: [creatorId], references: [id])
  members      TribeMember[]
  membersCount Int           @default(1)

  isPublic   Boolean  @default(true)
  isVerified Boolean  @default(false)
  coverKey   String?
  rules      String?
  tags       String[] @default([])

  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  posts Post[]

  @@unique([slug, city])
  @@index([city, category, isActive])
  @@index([city, membersCount])
  @@index([lat, lng])
}

model TribeMember {
  id       String   @id @default(cuid())
  userId   String
  tribeId  String
  user     User     @relation(fields: [userId], references: [id])
  tribe    Tribe    @relation(fields: [tribeId], references: [id])
  joinedAt DateTime @default(now())

  @@unique([userId, tribeId])
  @@index([tribeId])
  @@index([userId])
}

// ── Posts ────────────────────────────────────────────────

model Post {
  id       String   @id @default(cuid())
  authorId String
  author   User     @relation(fields: [authorId], references: [id])
  tribeId  String?
  tribe    Tribe?   @relation(fields: [tribeId], references: [id])
  city     String
  type     PostType @default(text)
  content  String   @db.Text

  // Media
  mediaKeys String[] @default([])

  // Event data (si type = event)
  eventTitle        String?
  eventDate         DateTime?
  eventLocation     String?
  eventMaxAttendees Int?
  eventAttendees    String[]  @default([])

  // Moderation
  isModerated Boolean @default(false)
  isFlagged   Boolean @default(false)
  isPinned    Boolean @default(false)

  // Stats denormalisees pour la perf
  reactionCounts Json @default("{}")
  commentsCount  Int  @default(0)

  reactions Reaction[]

  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([city, createdAt(sort: Desc)])
  @@index([tribeId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([deletedAt])
}

model Reaction {
  id     String @id @default(cuid())
  postId String
  userId String
  post   Post   @relation(fields: [postId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  emoji  String

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

// ── Partner CRM ──────────────────────────────────────────

model Partner {
  id           String        @id @default(cuid())
  userId       String?
  email        String        @unique
  businessName String
  contactName  String
  phone        String?
  city         String
  profileType  ProfileType
  status       PartnerStatus @default(lead)
  tier         PartnerTier   @default(standard)

  pipelineNotes    String    @default("")
  lastContactAt    DateTime?
  nextFollowUpAt   DateTime?
  contractSignedAt DateTime?

  annualValue Int  @default(0)
  invoices    Json @default("[]")

  source PartnerSource @default(inscription)
  tags   String[]      @default([])

  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([city, status])
  @@index([status, nextFollowUpAt])
  @@index([userId])
}

// ── Push Subscriptions ───────────────────────────────────

model PushSubscription {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  endpoint String  @unique
  p256dh   String
  auth     String
  platform String  @default("web")
  city     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([city, isActive])
}

// ── Moderation Log ───────────────────────────────────────

model ModerationLog {
  id         String  @id @default(cuid())
  postId     String
  action     String // approved | flagged | removed
  score      Float
  reason     String?
  autoAction Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([postId])
}
